{
  "manifest_version": 3,
  "name": "Web Data Studio",
  "short_name": "WebDataStudio",
  "version": "0.1.0",
  "description": "Visual web data extraction, transformation and export platform — tables, lists, cards and grids from any page.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "downloads",
    "contextMenus",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+D" },
      "description": "Open Web Data Studio"
    },
    "toggle-picker": {
      "suggested_key": { "default": "Ctrl+Shift+P" },
      "description": "Toggle command palette / element picker"
    },
    "quick-export": {
      "suggested_key": { "default": "Ctrl+Shift+E" },
      "description": "Quick export last extraction"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://surajit-singha-sisir.github.io https://cdn.tailwindcss.com;"
  },
  "minimum_chrome_version": "116"
}
